<ui:FluentWindow x:Class="ClipyFlow.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ClipyFlow Settings" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="SwatchStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="16" BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" BorderThickness="2" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings" Icon="pack://application:,,,/Assets/icon.png" />

        <ScrollViewer Grid.Row="1" Margin="20">
            <StackPanel>
                <TextBlock Text="General" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />

                <!-- Autorun -->
                <ui:CardAction Click="AutorunToggle_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Start with Windows" FontWeight="Medium" />
                            <TextBlock Text="Run ClipyFlow automatically when you sign in" Foreground="Gray" FontSize="12" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="ToggleAutorun" Grid.Column="1" IsChecked="{Binding Data.Settings.StartWithWindows, Mode=TwoWay}" />
                    </Grid>
                </ui:CardAction>

                <!-- Auto Paste -->
                <ui:CardAction>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Auto Paste" FontWeight="Medium" />
                            <TextBlock Text="Automatically paste items after clicking" Foreground="Gray" FontSize="12" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="ToggleAutoPaste" Grid.Column="1" IsChecked="{Binding Data.Settings.AutoPasteEnabled, Mode=TwoWay}" />
                    </Grid>
                </ui:CardAction>

                <!-- Theme -->
                <ui:CardAction>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Theme" FontWeight="Medium" />
                            <TextBlock Text="Select application theme" Foreground="Gray" FontSize="12" />
                        </StackPanel>
                        <ComboBox x:Name="ComboTheme" Grid.Column="1" Width="120" SelectedItem="{Binding Data.Settings.Theme, Mode=TwoWay}">
                            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">System</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Light</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Dark</System:String>
                        </ComboBox>
                    </Grid>
                </ui:CardAction>

                <!-- Hotkey -->
                <ui:CardAction>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Global Hotkey" FontWeight="Medium" />
                            <TextBlock Text="Press to open ClipyFlow" Foreground="Gray" FontSize="12" />
                        </StackPanel>
                        <ui:TextBox x:Name="TextHotkey" Grid.Column="1" Width="120" Text="{Binding Data.Settings.GlobalHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Alt+V" PreviewKeyDown="TextHotkey_PreviewKeyDown" IsReadOnly="True" Cursor="Hand" ToolTip="Click and press keys to record" />
                    </Grid>
                </ui:CardAction>

                <TextBlock Text="Customization" FontSize="20" FontWeight="SemiBold" Margin="0,15,0,10" />
                
                <!-- Background Image -->
                <StackPanel Margin="0,0,0,10">
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Background Image" FontWeight="Medium" VerticalAlignment="Center" />
                        <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon ArrowUndo24}" Click="BtnClearImage_Click" HorizontalAlignment="Right" Padding="4" ToolTip="Reset to Default" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="TextBgPath" Grid.Column="0" Text="{Binding Data.Settings.CustomBackgroundPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Select an image file..." Margin="0,0,5,0" />
                        <ui:Button Grid.Column="1" Content="Browse" Click="BtnBrowseImage_Click" />
                    </Grid>
                </StackPanel>

                <!-- Background Color Swatches -->
                <StackPanel Margin="0,0,0,10">
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Window Accent Color" FontWeight="Medium" VerticalAlignment="Center" />
                        <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon ArrowUndo24}" Click="BtnClearColor_Click" HorizontalAlignment="Right" Padding="4" ToolTip="Reset to Default" />
                    </Grid>
                    <ListBox ItemsSource="{Binding ModernColors}" 
                             SelectedItem="{Binding Data.Settings.CustomBackgroundColor, Mode=TwoWay}" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                             BorderThickness="0" Background="Transparent" Padding="0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Margin="0" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="2" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Width="30" Height="30" CornerRadius="15" Background="{Binding}" BorderThickness="3" BorderBrush="Transparent" Cursor="Hand">
                                                <ui:SymbolIcon x:Name="CheckIcon" Symbol="Checkmark24" Foreground="White" Visibility="Collapsed" FontSize="16"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                    <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>

                <!-- Opacity -->
                <StackPanel Margin="0,0,0,10">
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Background Opacity" FontWeight="Medium" VerticalAlignment="Center" />
                        <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon ArrowUndo24}" Click="BtnClearOpacity_Click" HorizontalAlignment="Right" Padding="4" ToolTip="Reset to Default" />
                    </Grid>
                    <Slider x:Name="SliderOpacity" Minimum="0.1" Maximum="1.0" Value="{Binding Data.Settings.CustomBackgroundOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                </StackPanel>

                <TextBlock Text="Integrations" FontSize="20" FontWeight="SemiBold" Margin="0,15,0,10" />

                <!-- Tenor API Key -->
                <StackPanel>
                    <TextBlock Text="Tenor API Key (for GIFs)" FontWeight="Medium" Margin="0,0,0,5" />
                    <ui:TextBox x:Name="TextTenorApiKey" Text="{Binding Data.Settings.TenorApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter your Google Tenor API key here" />
                    <TextBlock Text="Leave empty to disable GIF search." Foreground="Gray" FontSize="12" Margin="0,5,0,0" />
                </StackPanel>
                
                <StackPanel Margin="0,20,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                    <ui:Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,10,0"/>
                    <ui:Button Content="Save" Appearance="Primary" Click="BtnSave_Click" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
