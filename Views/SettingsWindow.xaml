<ui:FluentWindow x:Class="ClipyFlow.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ClipyFlow Settings" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings" Icon="pack://application:,,,/Assets/icon.png" />

        <ScrollViewer Grid.Row="1" Margin="20">
            <StackPanel>
                <TextBlock Text="General" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />

                <!-- Autorun -->
                <ui:CardAction Click="AutorunToggle_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Start with Windows" FontWeight="Medium" />
                            <TextBlock Text="Run ClipyFlow automatically when you sign in" Foreground="Gray" FontSize="12" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="ToggleAutorun" Grid.Column="1" IsChecked="{Binding Settings.StartWithWindows, Mode=TwoWay}" />
                    </Grid>
                </ui:CardAction>

                <!-- Auto Paste -->
                <ui:CardAction>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Auto Paste" FontWeight="Medium" />
                            <TextBlock Text="Automatically paste items after clicking" Foreground="Gray" FontSize="12" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="ToggleAutoPaste" Grid.Column="1" IsChecked="{Binding Settings.AutoPasteEnabled, Mode=TwoWay}" />
                    </Grid>
                </ui:CardAction>

                <!-- Theme -->
                <ui:CardAction>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Theme" FontWeight="Medium" />
                            <TextBlock Text="Select application theme" Foreground="Gray" FontSize="12" />
                        </StackPanel>
                        <ComboBox x:Name="ComboTheme" Grid.Column="1" Width="120" SelectedItem="{Binding Settings.Theme, Mode=TwoWay}">
                            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">System</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Light</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Dark</System:String>
                        </ComboBox>
                    </Grid>
                </ui:CardAction>

                <TextBlock Text="Integrations" FontSize="20" FontWeight="SemiBold" Margin="0,15,0,10" />

                <!-- Tenor API Key -->
                <StackPanel>
                    <TextBlock Text="Tenor API Key (for GIFs)" FontWeight="Medium" Margin="0,0,0,5" />
                    <ui:TextBox x:Name="TextTenorApiKey" Text="{Binding Settings.TenorApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter your Google Tenor API key here" />
                    <TextBlock Text="Leave empty to disable GIF search." Foreground="Gray" FontSize="12" Margin="0,5,0,0" />
                </StackPanel>
                
                <StackPanel Margin="0,20,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                    <ui:Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,10,0"/>
                    <ui:Button Content="Save" Appearance="Primary" Click="BtnSave_Click" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
