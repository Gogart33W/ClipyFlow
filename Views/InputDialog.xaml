<ui:FluentWindow x:Class="ClipyFlow.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Input" Height="160" Width="320"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="{Binding WindowTitle}" ShowMinimize="False" ShowMaximize="False" Margin="0,0,0,8" />
        <TextBlock Grid.Row="1" x:Name="PromptText" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
        <ui:TextBox Grid.Row="2" x:Name="InputBox" Margin="0,0,0,10" KeyDown="InputBox_KeyDown" />
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="Cancel" Appearance="Secondary" Margin="0,0,8,0" Click="Cancel_Click" />
            <ui:Button Content="OK" Appearance="Primary" Click="OK_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
