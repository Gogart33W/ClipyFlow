<Window x:Class="ClipyFlow.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Input" Height="170" Width="340"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        WindowStyle="ToolWindow">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="PromptText" Margin="0,0,0,10" FontSize="13"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
        <ui:TextBox Grid.Row="1" x:Name="InputBox" Margin="0,0,0,12" KeyDown="InputBox_KeyDown" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="Cancel" Appearance="Secondary" Margin="0,0,8,0" Click="Cancel_Click" />
            <ui:Button Content="OK" Appearance="Primary" Click="OK_Click" />
        </StackPanel>
    </Grid>
</Window>

