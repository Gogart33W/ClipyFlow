<ui:FluentWindow x:Class="ClipyFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ClipyFlow" Height="450" Width="350"
        Background="Transparent"
        ShowInTaskbar="False"
        Icon="pack://application:,,,/Assets/icon.png"
        Visibility="Hidden"
        Topmost="True"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">
        
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar to allow dragging -->
        <ui:TitleBar Grid.Row="0" Title="ClipyFlow" Margin="0,0,0,5" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" Margin="0,-10,0,-10">
                <StackPanel Margin="0,10,0,0">
                    <ui:Button x:Name="BtnNavHistory" Icon="{ui:SymbolIcon Clock24}" Width="40" Height="40" Margin="10,5" Appearance="Primary" Click="NavHistory_Click" ToolTip="History" />
                    <ui:Button x:Name="BtnNavSnippets" Icon="{ui:SymbolIcon Pin24}" Width="40" Height="40" Margin="10,5" Appearance="Transparent" Click="NavSnippets_Click" ToolTip="Pinned Snippets" />
                    <ui:Button x:Name="BtnNavLibrary" Icon="{ui:SymbolIcon Code24}" Width="40" Height="40" Margin="10,5" Appearance="Transparent" Click="NavLibrary_Click" ToolTip="Smart Library" />
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Search and Clear Button -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="InputSearch" Grid.Column="0" PlaceholderText="Search clipboard..." Icon="{ui:SymbolIcon Search24}" TextChanged="SearchBox_TextChanged" />
                    <ui:Button x:Name="BtnClearHistory" Grid.Column="1" Margin="5,0,0,0" Icon="{ui:SymbolIcon Delete24}" Appearance="Danger" Click="ClearHistory_Click" ToolTip="Clear History" />
                </Grid>

                <!-- Views -->
                <Grid Grid.Row="1">
                    
                    <!-- History List -->
                    <ListView x:Name="ViewHistory" Visibility="Visible" ItemsSource="{Binding History}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonUp="HistoryList_PreviewMouseLeftButtonUp">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Background="{DynamicResource ControlFillColorDefaultBrush}" Margin="0,0,0,5" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Icon based on type -->
                                        <ui:SymbolIcon Grid.Column="0" Margin="0,0,10,0" FontSize="20">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Symbol" Value="Document24" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ItemType}" Value="Link">
                                                            <Setter Property="Symbol" Value="Link24" />
                                                            <Setter Property="Foreground" Value="#0078D7" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ItemType}" Value="Code">
                                                            <Setter Property="Symbol" Value="Code24" />
                                                            <Setter Property="Foreground" Value="#D69D85" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ItemType}" Value="Color">
                                                            <Setter Property="Symbol" Value="Color24" />
                                                            <Setter Property="Foreground" Value="{Binding HexColor}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>

                                        <!-- Text Content -->
                                        <TextBlock Grid.Column="1" Text="{Binding Text}" TextTrimming="CharacterEllipsis" MaxHeight="40" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,10,0" />

                                        <!-- Pin Button -->
                                        <ui:Button Grid.Column="2" Appearance="Transparent" Click="PinHistory_Click" ToolTip="Toggle Pin" Padding="4">
                                            <ui:SymbolIcon FontSize="20">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Symbol" Value="Pin24" />
                                                        <Setter Property="Foreground" Value="Gray" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                <Setter Property="Foreground" Value="#FFD700" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                        </ui:Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Snippets List -->
                    <ListView x:Name="ViewSnippets" Visibility="Collapsed" ItemsSource="{Binding Snippets}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonUp="SnippetsList_PreviewMouseLeftButtonUp">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Background="{DynamicResource ControlFillColorDefaultBrush}" Margin="0,0,0,5" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <ui:SymbolIcon Grid.Column="0" Margin="0,0,10,0" FontSize="20" Symbol="Pin24" Foreground="#FFD700" />
                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="{Binding Content}" TextTrimming="CharacterEllipsis" MaxHeight="20" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>

                                        <!-- Unpin Button -->
                                        <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent" Foreground="#FF5555" Click="UnpinSnippet_Click" ToolTip="Unpin Snippet" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Library List -->
                    <TabControl x:Name="ViewLibrary" Visibility="Collapsed" ItemsSource="{Binding LibraryCategories}" Background="Transparent" BorderThickness="0">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LanguageName}" FontWeight="Bold" Margin="5,0"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <ListView ItemsSource="{Binding Snippets}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonUp="LibraryList_PreviewMouseLeftButtonUp">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Background="{DynamicResource ControlFillColorDefaultBrush}" Margin="0,0,0,5" Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <ui:SymbolIcon Grid.Column="0" Margin="0,0,10,0" FontSize="20" Symbol="Code24" Foreground="#D69D85" />
                                                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Content}" TextTrimming="CharacterEllipsis" MaxHeight="60" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding UsageCount, StringFormat='{}Used: {0}'}" Foreground="Gray" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
