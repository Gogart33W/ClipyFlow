<ui:FluentWindow x:Class="ClipyFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:conv="clr-namespace:ClipyFlow.Converters"
        xmlns:local="clr-namespace:ClipyFlow.Views"
        Title="ClipyFlow" Height="500" Width="400"
        Background="Transparent"
        ShowInTaskbar="False"
        Icon="pack://application:,,,/Assets/icon.png"
        Visibility="Hidden"
        Topmost="True"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">
        
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:HexToBrushConverter x:Key="HexToBrushConverter" />
    </Window.Resources>
    
    <Grid>
        <!-- Custom Background Layer -->
        <Border x:Name="CustomBgColor" Background="Transparent" />
        <Image x:Name="CustomBgImage" Stretch="UniformToFill" />

        <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar to allow dragging -->
        <ui:TitleBar Grid.Row="0" Title="ClipyFlow" Margin="0,0,0,5" ShowMinimize="False" ShowMaximize="False" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" Margin="0,-10,0,-10">
                <Grid>
                    <StackPanel Margin="0,10,0,0">
                        <ui:Button x:Name="BtnNavHistory" Icon="{ui:SymbolIcon Clock24}" Width="40" Height="40" Margin="10,5" Appearance="Primary" Click="NavHistory_Click" ToolTip="History" />
                        <ui:Button x:Name="BtnNavSnippets" Icon="{ui:SymbolIcon Pin24}" Width="40" Height="40" Margin="10,5" Appearance="Transparent" Click="NavSnippets_Click" ToolTip="Pinned Snippets" />
                        <ui:Button x:Name="BtnNavLibrary" Icon="{ui:SymbolIcon Code24}" Width="40" Height="40" Margin="10,5" Appearance="Transparent" Click="NavLibrary_Click" ToolTip="Smart Library" />
                        <ui:Button x:Name="BtnNavEmoji" Icon="{ui:SymbolIcon Sticker24}" Width="40" Height="40" Margin="10,5" Appearance="Transparent" Click="NavEmoji_Click" ToolTip="Emoji" />
                        <ui:Button x:Name="BtnNavGif" Icon="{ui:SymbolIcon Gif24}" Width="40" Height="40" Margin="10,5" Appearance="Transparent" Click="NavGif_Click" ToolTip="Tenor GIFs" />
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,10">
                        <ui:Button x:Name="BtnNavSettings" Icon="{ui:SymbolIcon Settings24}" Width="40" Height="40" Margin="10,5" Appearance="Transparent" Click="NavSettings_Click" ToolTip="Settings" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Search and Clear Button -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="InputSearch" Grid.Column="0" PlaceholderText="Search clipboard..." Icon="{ui:SymbolIcon Search24}" TextChanged="SearchBox_TextChanged" PreviewKeyDown="InputSearch_PreviewKeyDown" />
                    <Primitives:ToggleButton xmlns:Primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework" x:Name="TogglePinWindow" Grid.Column="1" Margin="5,0,0,0" Background="Transparent" BorderThickness="0" ToolTip="Pin Window (Keep open)">
                        <ui:SymbolIcon Symbol="Pin24">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=Primitives:ToggleButton}}" Value="True">
                                            <Setter Property="Foreground" Value="#FFD700" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </Primitives:ToggleButton>
                    <ui:Button x:Name="BtnClearHistory" Grid.Column="2" Margin="5,0,0,0" Icon="{ui:SymbolIcon Delete24}" Appearance="Danger" Click="ClearHistory_Click" ToolTip="Clear History" />
                </Grid>

                <!-- Views -->
                <Grid Grid.Row="1">
                    
                    <!-- History List -->
                    <ListView x:Name="ViewHistory" Visibility="Visible" ItemsSource="{Binding History}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="5,10,0,5"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <ui:CardAction Click="HistoryItem_Click" Margin="0,0,0,5" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Icon based on type -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                                            <ui:SymbolIcon FontSize="20">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Symbol" Value="Document24" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ItemType}" Value="Link">
                                                                <Setter Property="Symbol" Value="Link24" />
                                                                <Setter Property="Foreground" Value="#0078D7" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ItemType}" Value="Code">
                                                                <Setter Property="Symbol" Value="Code24" />
                                                                <Setter Property="Foreground" Value="#D69D85" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ItemType}" Value="Color">
                                                                <Setter Property="Symbol" Value="Color24" />
                                                                <Setter Property="Foreground" Value="{Binding HexColor, Converter={StaticResource HexToBrushConverter}}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ItemType}" Value="Image">
                                                                <Setter Property="Symbol" Value="Image24" />
                                                                <Setter Property="Foreground" Value="#00CC6A" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                            <Rectangle Width="16" Height="16" Margin="5,0,0,0" RadiusX="4" RadiusY="4" Fill="{Binding HexColor, Converter={StaticResource HexToBrushConverter}}">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ItemType}" Value="Color">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>
                                        </StackPanel>

                                        <!-- Content -->
                                        <Grid Grid.Column="1" Margin="0,0,10,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            
                                            <TextBlock Grid.Row="0" Text="{Binding CopiedAt, StringFormat={}{0:HH:mm}}" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,2" />
                                            
                                            <TextBlock Grid.Row="1" Text="{Binding Text}" ToolTip="{Binding Text}" TextTrimming="CharacterEllipsis" MaxHeight="40" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ItemType}" Value="Image">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            
                                            <Image Grid.Row="1" Source="{Binding ImagePath}" MaxHeight="60" Stretch="Uniform" HorizontalAlignment="Left">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ItemType}" Value="Image">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>

                                        <!-- Buttons -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <ui:Button Appearance="Transparent" Click="DeleteHistory_Click" ToolTip="Delete Item" Padding="4">
                                                <ui:SymbolIcon Symbol="Delete24" Foreground="#FF5555" FontSize="20" />
                                            </ui:Button>
                                            <ui:Button Appearance="Transparent" Click="PinHistory_Click" ToolTip="Toggle Pin" Padding="4">
                                            <ui:SymbolIcon FontSize="20">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Symbol" Value="Pin24" />
                                                        <Setter Property="Foreground" Value="Gray" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                <Setter Property="Foreground" Value="#FFD700" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                            </ui:Button>
                                        </StackPanel>
                                    </Grid>
                                </ui:CardAction>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Snippets List -->
                    <ListView x:Name="ViewSnippets" Visibility="Collapsed" ItemsSource="{Binding Snippets}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="SnippetsList_MouseDoubleClick">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Background="{DynamicResource ControlFillColorDefaultBrush}" Margin="0,0,0,5" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <ui:SymbolIcon Grid.Column="0" Margin="0,0,10,0" FontSize="20" Symbol="Pin24" Foreground="#FFD700" />
                                        <!-- Edit Mode -->
                                        <StackPanel Grid.Column="1" Margin="0,0,10,0" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                            <ui:TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5" PlaceholderText="Title" />
                                            <ui:TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="60" PlaceholderText="Content" />
                                            <ui:Button Content="Save" Appearance="Primary" Click="SaveSnippet_Click" Margin="0,5,0,0" HorizontalAlignment="Right" Padding="10,2"/>
                                        </StackPanel>

                                        <!-- View Mode -->
                                        <ContentControl Grid.Column="1" Margin="0,0,10,0" Background="Transparent" MouseDoubleClick="SnippetText_DoubleClicked">
                                            <ContentControl.Style>
                                                <Style TargetType="ContentControl">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ContentControl.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{Binding Content}" TextTrimming="CharacterEllipsis" MaxHeight="20" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </ContentControl>

                                        <!-- Unpin Button -->
                                        <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent" Foreground="#FF5555" Click="UnpinSnippet_Click" ToolTip="Unpin Snippet" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Library List -->
                    <TabControl x:Name="ViewLibrary" Visibility="Collapsed" ItemsSource="{Binding LibraryCategories}" Background="Transparent" BorderThickness="0">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LanguageName}" FontWeight="Bold" Margin="5,0"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <ListView ItemsSource="{Binding Snippets}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="LibraryList_MouseDoubleClick">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Background="{DynamicResource ControlFillColorDefaultBrush}" Margin="0,0,0,5" Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <ui:SymbolIcon Grid.Column="0" Margin="0,0,10,0" FontSize="20" Symbol="Code24" Foreground="#D69D85" />
                                                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Content}" TextTrimming="CharacterEllipsis" MaxHeight="60" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding UsageCount, StringFormat='{}Used: {0}'}" Foreground="Gray" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <!-- Emoji List -->
                    <local:EmojiControl x:Name="ViewEmoji" Grid.Row="1" Visibility="Collapsed" EmojiSelected="EmojiControl_EmojiSelected" />
                    <local:GifControl x:Name="ViewGif" Visibility="Collapsed" GifSelected="GifControl_GifSelected" />

                </Grid>
            </Grid>
        </Grid>
    </Grid>
    </Grid>
</ui:FluentWindow>
